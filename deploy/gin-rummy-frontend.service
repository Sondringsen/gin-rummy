[Unit]
Description=Gin Rummy Frontend
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/gin-rummy/frontend
ExecStart=/home/ec2-user/.nvm/versions/node/v24.14.1/bin/npm start -- -p 3000
Environment=PATH=/home/ec2-user/.nvm/versions/node/v24.14.1/bin:/usr/local/bin:/usr/bin:/bin
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
